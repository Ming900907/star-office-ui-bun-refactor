# Star Office UI Bun refactor - environment example

# Environment mode: development | production
STAR_OFFICE_ENV=development

# Server bind
HOST=127.0.0.1
PORT=19000

# Asset editor password (MUST change in production)
ASSET_DRAWER_PASS=replace_with_strong_password
ASSET_AUTH_COOKIE_SECURE=1
ASSET_MAX_UPLOAD_BYTES=10485760

# API token used for sensitive write endpoints (required in production)
STAR_OFFICE_API_TOKEN=replace_with_long_random_token

# Basic in-memory rate limits
AUTH_RATE_LIMIT_PER_MIN=20
JOIN_RATE_LIMIT_PER_MIN=60

# Optional auto-rotate flags
AUTO_ROTATE_HOME_ON_PAGE_OPEN=0
AUTO_ROTATE_MIN_INTERVAL_SECONDS=60

# Feature flags (default: control/decoration off, agent skills on)
ENABLE_STATE_CONTROL=0
ENABLE_ASSET_DECORATION=0
ENABLE_AGENT_SKILLS_API=1

# OpenClaw panel sync is cache-driven:
# OpenClaw should call POST /openclaw/sync, then frontend GET endpoints read cached snapshots.
# Server executes local OpenClaw CLI during sync:
# - openclaw skills list --json
# - openclaw status --usage --json
OPENCLAW_BIN=openclaw
OPENCLAW_CLI_TIMEOUT_MS=6000
OPENCLAW_CACHE_STALE_SECONDS=120
# Optional strict mode:
# - 0: allow degraded fallback in production
# - 1: require healthy skills/usage sources and fail requests/bootstrap when degraded
OPENCLAW_REQUIRE_HEALTHY_SOURCE=0

# Agent push script:
# - state push interval
# - panel sync interval (0 to disable)
OFFICE_PUSH_INTERVAL_SECONDS=15
OFFICE_PANEL_SYNC_INTERVAL_SECONDS=60

# set-state script defaults
STAR_OFFICE_URL=http://127.0.0.1:19000
STAR_OFFICE_SET_STATE_MODE=http
# For file mode fallback:
# STAR_OFFICE_STATE_FILE=/absolute/path/to/state.json
